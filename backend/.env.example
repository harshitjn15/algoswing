# =============================================
# AlgoSwing Backend — Environment Variables
# Copy to .env and fill in values
# =============================================

# Application
APP_ENV=development
APP_NAME=AlgoSwing
APP_VERSION=1.0.0
DEBUG=true
PORT=8000

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=algoswing

# Upstox Market Data
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here

# Zerodha (Phase 4)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_FROM_EMAIL=alerts@algoswing.com
ALERT_TO_EMAIL=your_email@gmail.com

# Clerk (Frontend Auth)
CLERK_SECRET_KEY=sk_test_...

# CORS
CORS_ORIGINS=http://localhost:3000,https://algoswing.vercel.app

# Scanner Config
SCANNER_INTERVAL_MINUTES=30
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
MARKET_TIMEZONE=Asia/Kolkata

# Strategy Defaults
DEFAULT_ATH_RANGE_PCT=5.0
DEFAULT_VOLUME_MULTIPLIER=1.5
DEFAULT_MAX_SL_PCT=15.0
DEFAULT_TP1_PCT=10.0
DEFAULT_TP2_PCT=15.0
DEFAULT_TP3_PCT=20.0
DEFAULT_RETEST_ZONE_LOW_PCT=1.0
DEFAULT_RETEST_ZONE_HIGH_PCT=3.0
